<%= render "teams/show_shared" %>

<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h2 class="mb-0">Pending Applications</h2>
    <% if @pending_applications.any? %>
      <span class="badge bg-warning text-dark"><%= @pending_applications.count %></span>
    <% end %>
  </div>
  <div class="card-body">
    <% if @pending_applications.any? %>
      <% @pending_applications.each do |application| %>
        <div class="row align-items-center py-2 border-bottom">
          <div class="col-6 col-md-3 col-lg-2">
            <%= link_to person_path(application.person) do %>
              <%= image_tag get_avatar_url_64(application.person.avatar), class: "person-img" %>
            <% end %>
          </div>
          <div class="col-6 col-md">
            <%= link_to application.person.display_name, person_path(application.person) %>
            <% if application.message.present? %>
              <div class="text-muted small"><%= truncate(application.message, length: 120) %></div>
            <% end %>
          </div>
          <div class="col-12 col-md-4 d-flex gap-2">
            <%= link_to "View", team_membership_application_path(@team, application), class: "btn btn-sm me-3 btn-outline-primary" %>
            <%= link_to "Approve", team_membership_application_path(@team, application, status: "approved"), class: "btn btn-sm btn-success", data: { turbo_method: :patch } %>
            <%= link_to "Deny", team_membership_application_path(@team, application, status: "denied"), class: "btn btn-sm btn-danger", data: { turbo_method: :patch } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-muted mb-0">No pending applications.</p>
    <% end %>
  </div>
</div>
