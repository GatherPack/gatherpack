<%= render "show_shared" %>

<div class="card">
  <div class="card-header">
    <h1>Events</h1>
  </div>
  <div class="card-body">
    <div id="events" class="row">
      <% @events.each do |event| %>
        <div class="col-md-3">
          <%= render event %>
        </div>
      <% end %>
    </div>
    <%= paginate @events %>
  </div>
</div>
