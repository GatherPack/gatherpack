<%= render "show_shared" %>

<div class="card">
  <div class="card-header">
    <h1>Pages</h1>
  </div>
  <div class="card-body">
    <div id="pages" class="row">
      <% @pages.each do |page| %>
        <div class="col-md-3">
          <%= render page %>
        </div>
      <% end %>
    </div>
    <%= paginate @pages %>
  </div>
</div>
