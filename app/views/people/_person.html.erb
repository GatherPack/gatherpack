<div class="card" id="<%= dom_id person %>">
  <div class="card-header">
    <%= link_to person.identifier_name, person, "data-turbo": "false" %>
  </div>
  <div class="card-body">
    <%= image_tag get_avatar_url(person.avatar), class: 'person-img' %>
  </div>
  <% if local_assigns[:footer]%>
    <div class="card-footer">
      <%= local_assigns[:footer] %>
    </div>
  <% end %>
</div>
