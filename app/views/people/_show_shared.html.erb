<% breadcrumb @person %>

<div class="card navtab">
  <ul class="nav nav-underline">
    <li class="nav-item">
      <a href="<%= person_path(@person) %>" class="nav-link <%= "active" if current_page?(person_path(@person)) %>">Overview</a>
    </li>
    <li class="nav-item">
      <a href="<%= person_memberships_path(@person) %>" class="nav-link <%= "active" if current_page?(person_memberships_path(@person)) %>">Teams</a>
    </li>
    <li class="nav-item">
      <a href="<%= relationships_person_path(@person) %>" class="nav-link <%= "active" if current_page?(relationships_person_path(@person)) %>">Relationships</a>
    </li>
    <li class="nav-item">
      <a href="<%= recent_activity_person_path(@person) %>" class="nav-link <%= "active" if current_page?(recent_activity_person_path(@person)) %>">Recent Activity</a>
    </li>
    <% if GatherPack::Features.enabled?(:events) %>
      <li class="nav-item">
        <a href="<%= calendar_person_path(@person) %>" class="nav-link <%= "active" if current_page?(calendar_person_path(@person)) %>">Calendar</a>
      </li>
    <% end %>
    <% if GatherPack::Features.enabled?(:events) || GatherPack::Features.enabled?(:time_tracking) %>
      <li class="nav-item">
        <a href="<%= statistics_person_path(@person) %>" class="nav-link <%= "active" if current_page?(statistics_person_path(@person)) %>">Statistics</a>
      </li>
    <% end %>

  </ul>
</div>
