<div class="card mb-3">
  <div class="card-header">
    <h5 class="mb-0">Filter Time Clock Punches</h5>
  </div>
  <div class="card-body">
    <%= form_with url: summary_time_clock_period_path(@time_clock_period), method: :get, class: "row g-3" do |f| %>
      <div class="col-md-4">
        <%= f.label :starts_at, "Starts At", class: "form-label" %>
        <%= f.datetime_local_field :starts_at, value: @start_date.strftime("%Y-%m-%dT%H:%M"), class: "form-control" %>
      </div>
      <div class="col-md-4">
        <%= f.label :ends_at, "Ends At", class: "form-label" %>
        <%= f.datetime_local_field :ends_at, value: @end_date.strftime("%Y-%m-%dT%H:%M"), class: "form-control" %>
      </div>
      <div class="col-md-4 d-flex align-items-end">
        <%= f.submit "Filter", class: "btn btn-primary me-2" %>
        <%= link_to "Clear", summary_time_clock_period_path(@time_clock_period), class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>

<div class="card mb-3">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h1 class="mb-0"><%= @time_clock_period.name %> — Daily Summary</h1>
    <span class="text-muted small">
      <%= @start_date.to_date.strftime("%b %-d, %Y") %> –
      <%= @end_date.to_date.strftime("%b %-d, %Y") %>
    </span>
  </div>
  <div class="card-body py-2">
    <div>
      <span class="me-3"><strong>Total hours:</strong> <%= @total_hours %></span>
      <span><strong>Total people:</strong> <%= @total_people %></span>
    </div>
    <div class="row">
      <% @people.each do |person| %>
      <div class="col-2 col-lg-1">
        <%= link_to(image_tag(get_avatar_url(person.avatar), class: 'person-img'), person) %>
      </div>
      <% end %>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <div data-controller="calendar"
         data-calendar-timezone-value="<%= Settings[:time_zone].presence || 'UTC' %>"
         data-calendar-default-view-value="dayGridMonth"
         data-calendar-start-time-value="<%= @time_clock_period.start_time.iso8601 %>"
         data-calendar-inline-events-value="<%= @calendar_events.to_json %>">
      <div id="calendar" data-turbo="false">
      </div>
    </div>
  </div>
</div>
