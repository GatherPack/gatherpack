<% breadcrumb :arrange_event, @event %>

<div class="card">
  <div class="card-header">
    <h1>Arranging <%= @event.identifier_name %></h1>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-12 col-md-6">
        <%= form_with url: arrange_event_path(@event), method: "GET" do |f| %>
          <%= f.label :field_id, "Arrange By", class: 'form-label' %>
          <%= f.collection_select :field_id, @event.event_type.checkin_fields, :id, :name, { }, selected: params[:field_id], class: 'form-control mb-3' %>

          <div class="d-flex flex-row">
            <%= f.submit 'Start Arranging', class: 'btn btn-primary' %>
            <%= link_to 'Print', print_event_path(@event, field_id: params[:field_id]), class: 'btn btn-dark ms-2' if @field.present? %>
          </div>
        <% end %>
      </div>
      <div class="col-12 col-md-6">
        <% if @field.present? %>
          <label name="newField" class="form-label">New <%= @field.name %> Value</label>
          <input name="newField" id="newField" type="text" class="form-control mb-3">
          <button id="addNewField" class="btn btn-primary">Add New <%= @field.name %></button>
        <% end %>
      </div>
    </div>
  </div>
</div>

<% if @field.present? %>
  <div class="card">
    <div class="card-header">
      <h2>Arranging by <%= @field.name %></h2>
    </div>
    <div class="card-body" id="responseContainer">
      <% @responses.pluck(:response).uniq.sort_by { |v| v || 'zzzzz' }.each do |v| %>
        <div class="row align-items-center">
          <div class="col-12 col-md-4 col-xl-2">
            <h3 class="d-flex align-items-center gap-2">
              <span class="arranging-label" data-arranging-label="<%= URI.encode_uri_component v %>"><%= v.presence || 'unassigned' %></span>
              [<span data-arranging-count="<%= URI.encode_uri_component v %>"><%= @responses.where(response: v).count %></span>]
              <button class="btn btn-sm btn-outline-secondary rename-btn" title="Rename"
                data-arranging-label="<%= URI.encode_uri_component v %>"
                data-current-value="<%= v.presence || '' %>">&#9998;</button>
            </h3>
          </div>
          <div class="col-12 col-md-8 col-xl-10">
            <div class="badge-container arranging-container" data-arranging-container="<%= URI.encode_uri_component v %>">
              <% @responses.where(response: v).order('person.last_name ASC, person.first_name ASC').each do |r| %>
                <div class="badge arranging-badge" draggable="true" id="<%= r.id %>"><%= r.checkin.person.identifier_name %></div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<div class="modal fade" id="renameModal" tabindex="-1" aria-labelledby="renameModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="renameModalLabel">Rename</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="alert alert-danger d-none" id="renameError"></div>
        <label for="renameInput" class="form-label">New name</label>
        <input type="text" id="renameInput" class="form-control">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="renameSave">Save</button>
      </div>
    </div>
  </div>
</div>

<script>
  function dragstartHandler(ev) {
    ev.dataTransfer.setData("text/plain", ev.target.id);
  }

  function dragoverHandler(ev) {
    ev.preventDefault();
    ev.dataTransfer.dropEffect = "move";
  }

  function dropHandler(ev) {
    ev.preventDefault();
    const data = ev.dataTransfer.getData("text/plain");
    const draggedElement = document.getElementById(data);
    const sourceContainer = draggedElement.parentElement;
    const sourceContainerName = sourceContainer.dataset.arrangingContainer;
    const targetContainerName = ev.target.dataset.arrangingContainer;
    
    ev.target.appendChild(draggedElement);

    // Update counters
    const sourceCounter = document.querySelector(`[data-arranging-count="${sourceContainerName}"]`);
    const targetCounter = document.querySelector(`[data-arranging-count="${targetContainerName}"]`);
    
    if (sourceCounter) {
      sourceCounter.textContent = parseInt(sourceCounter.textContent) - 1;
    }
    if (targetCounter) {
      targetCounter.textContent = parseInt(targetCounter.textContent) + 1;
    }

    const csrfToken = document.querySelector("[name='csrf-token']").content

    fetch("/events/<%= @event.id %>/field_update", {
      method: "PATCH",
      headers: {
        "X-CSRF-Token": csrfToken,
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ field_id: data, response: decodeURIComponent(ev.target.dataset.arrangingContainer) })
    }).then(response => {
      if (!response.ok) { throw response; }
    }).catch(error => {
      console.error("error", error);
    })
  }

  function addNewFieldHandler(ev) {
    const val = document.getElementById("newField").value;
    const encoded = encodeURIComponent(val);
    const template = `<div class="row align-items-center">
          <div class="col-12 col-md-4 col-xl-2">
            <h3 class="d-flex align-items-center gap-2">
              <span class="arranging-label" data-arranging-label="${encoded}">${val}</span>
              [<span data-arranging-count="${encoded}">0</span>]
              <button class="btn btn-sm btn-outline-secondary rename-btn" title="Rename"
                data-arranging-label="${encoded}" data-current-value="${val}">&#9998;</button>
            </h3>
          </div>
          <div class="col-12 col-md-8 col-xl-10">
            <div class="badge-container arranging-container" data-arranging-container="${encoded}">
            </div>
          </div>
        </div>`;
    document.getElementById("responseContainer").insertAdjacentHTML("afterbegin", template);
    const zones = document.querySelectorAll(".arranging-container");
    zones.forEach( (e) => { e.addEventListener("drop", dropHandler) });
    zones.forEach( (e) => { e.addEventListener("dragover", dragoverHandler) });
    bindRenameButtons();
  }

  let renameModal;
  let renamePendingEncoded = null;

  window.addEventListener("turbo:load", () => {
    const element = document.querySelectorAll(".arranging-badge");
    element.forEach( (e) => { e.addEventListener("dragstart", dragstartHandler) });

    const zones = document.querySelectorAll(".arranging-container");
    zones.forEach( (e) => { e.addEventListener("drop", dropHandler) });
    zones.forEach( (e) => { e.addEventListener("dragover", dragoverHandler) });

    document.getElementById("addNewField").addEventListener("click", addNewFieldHandler);

    renameModal = new bootstrap.Modal(document.getElementById("renameModal"));

    document.getElementById("renameSave").addEventListener("click", renameSubmitHandler);
    document.getElementById("renameInput").addEventListener("keydown", (ev) => {
      if (ev.key === "Enter") renameSubmitHandler();
    });

    bindRenameButtons();
  });

  function bindRenameButtons() {
    document.querySelectorAll(".rename-btn").forEach((btn) => {
      if (btn.dataset.renameBound) return;
      btn.dataset.renameBound = "1";
      btn.addEventListener("click", () => {
        renamePendingEncoded = btn.dataset.arrangingLabel;
        document.getElementById("renameInput").value = btn.dataset.currentValue;
        document.getElementById("renameError").classList.add("d-none");
        renameModal.show();
        setTimeout(() => document.getElementById("renameInput").select(), 300); 
      });
    });
  }

  function renameSubmitHandler() {
    if (!renamePendingEncoded) return;
    const oldEncoded = renamePendingEncoded;
    const newVal = document.getElementById("renameInput").value.trim();
    const newEncoded = encodeURIComponent(newVal);
    const csrfToken = document.querySelector("[name='csrf-token']").content;
    const saveBtn = document.getElementById("renameSave");
    const errorEl = document.getElementById("renameError");

    saveBtn.disabled = true;

    fetch("/events/<%= @event.id %>/rename_response", {
      method: "PATCH",
      headers: {
        "X-CSRF-Token": csrfToken,
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        field_id: "<%= params[:field_id] %>",
        old_response: decodeURIComponent(oldEncoded),
        new_response: newVal
      })
    }).then((response) => {
      if (!response.ok) { throw new Error(`Server error ${response.status}`); }

      // Update label text & data attributes
      const label = document.querySelector(`.arranging-label[data-arranging-label="${oldEncoded}"]`);
      label.textContent = newVal || "unassigned";
      label.dataset.arrangingLabel = newEncoded;

      const counter = document.querySelector(`[data-arranging-count="${oldEncoded}"]`);
      counter.dataset.arrangingCount = newEncoded;

      const container = document.querySelector(`.arranging-container[data-arranging-container="${oldEncoded}"]`);
      container.dataset.arrangingContainer = newEncoded;

      const renameBtn = document.querySelector(`.rename-btn[data-arranging-label="${oldEncoded}"]`);
      renameBtn.dataset.arrangingLabel = newEncoded;
      renameBtn.dataset.currentValue = newVal;

      renamePendingEncoded = null;
      renameModal.hide();
    }).catch((error) => {
      errorEl.textContent = `Rename failed: ${error.message}`;
      errorEl.classList.remove("d-none");
    }).finally(() => {
      saveBtn.disabled = false;
    });
  }
</script>