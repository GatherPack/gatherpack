<div class="card">
  <div class="card-header">
    <%= version.created_at %>
  </div>
  <div class="card-body">
    <ul class="list-unstyled">
      <li>Item ID: <%= version.item_id %></li>
      <li>Event: <%= version.event %></li>
      <li>Whodunnit: <%= version.whodunnit %></li>
    </ul>
    <%= link_to 'View', audit_log_path(version.id), class: 'btn btn-secondary' %>
  </div>
</div>
