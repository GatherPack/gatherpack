<% breadcrumb @question %>

<%= simple_form_for(@question) do |f| %>
  <div class="card">
    <div class="card-header">
      <h1>New Question</h1>
    </div>
    <div class="card-body">
      <%= render "form", f: f %>
    </div>
    <div class="card-footer">
      <%= link_to "Cancel", questions_path, class: "btn btn-warning" %>
      <%= f.button :submit, class: "btn btn-primary" %>
    </div>
  </div>
<% end %>
