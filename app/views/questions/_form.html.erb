<%= f.error_notification %>
<%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

<div class="form-inputs">
  <div class="row">
    <div class="col-12 col-md-6">
      <%= f.input :title %>
    </div>
    <div class="col-12 col-md-6">
      <%= f.input :team_id, as: :searching_combobox, label: "Team", scope: "managed_teams", include_blank: false %>
    </div>
  </div>

  <%= f.input :content, wrapper_html: { class: "code-editor" }, input_html: { rows: 6, data: { lang: "markdown" } } %>
</div>
