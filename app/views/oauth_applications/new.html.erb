<% breadcrumb @oauth_application %>

<%= simple_form_for(@oauth_application) do |f| %>
  <div class="card">
    <div class="card-header">
      <h1>New OAuth Application</h1>
    </div>
    <div class="card-body">
      <%= render "form", f: f %>
    </div>
    <div class="card-footer">
      <%= link_to "Cancel", oauth_applications_path, class: 'btn btn-warning' %>
      <%= f.button :submit, class: 'btn btn-primary' %>
    </div>
  </div>
<% end %>
