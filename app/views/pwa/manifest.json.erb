<% theme = Theme.instance %>
{
  "name": "<%= Settings[:title] %>",
  "short_name": "",
  "icons": [
    {
      "src": "<%= theme.pwa_icon_192 ? url_for(theme.pwa_icon_192) : "/android-chrome-192x192.png" %>",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "<%= theme.pwa_icon_512 ? url_for(theme.pwa_icon_512) : "/android-chrome-512x512.png" %>",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "theme_color": "<%= theme.pwa_theme_color.presence || "#ffffff" %>",
  "background_color": "<%= theme.pwa_background_color.presence || "#ffffff" %>",
  "display": "standalone",
  "start_url": "/",
  "scope": "/",
  "description": "Get together with GatherPack"
}
